{
  "expo": {
    "name": "Breeze RMM",
    "slug": "breeze-rmm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.breeze.rmm",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock the app",
        "NSCameraUsageDescription": "Camera access for QR code scanning",
        "NSSpeechRecognitionUsageDescription": "Use voice to ask Breeze about your fleet.",
        "NSMicrophoneUsageDescription": "Use voice to ask Breeze about your fleet."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A0A0B"
      },
      "package": "com.breeze.rmm",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Breeze RMM to use Face ID for authentication"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Use voice to ask Breeze about your fleet.",
          "speechRecognitionPermission": "Use voice to ask Breeze about your fleet."
        }
      ],
      "@sentry/react-native/expo"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
