{
  "name": "@breeze/web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/compute-uninstall-sha256.ts",
    "presync:scripts": "node --experimental-strip-types scripts/compute-uninstall-sha256.ts",
    "dev": "astro dev",
    "build": "astro build",
    "build:prod": "NODE_ENV=production astro build",
    "preview": "astro preview",
    "preview:docker": "NODE_ENV=production astro preview --host 0.0.0.0 --port ${PORT:-4321}",
    "prod:docker": "pnpm run build:prod && pnpm run preview:docker",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --ext .ts,.tsx src",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/tailwind": "^6.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.6.0",
    "@novnc/novnc": "1.7.0",
    "@sentry/astro": "^10.56.0",
    "@tanstack/react-query": "^5.100.14",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "astro": "^6.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
