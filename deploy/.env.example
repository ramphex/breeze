# Breeze RMM - Production Environment
# Copy to .env on each droplet and fill in region-specific values.
#
# Usage: docker compose -f deploy/docker-compose.prod.yml --env-file .env up -d

# ── Region ──────────────────────────────────────────────────────────
BREEZE_DOMAIN=
CORS_ALLOWED_ORIGINS=https://${BREEZE_DOMAIN}
SENTRY_ENVIRONMENT=production

# ── Release image integrity ────────────────────────────────────────
# BREEZE_VERSION is informational/runtime metadata. Container immutability is
# enforced by digest-pinned image refs below.
BREEZE_VERSION=0.0.0
BREEZE_API_IMAGE_DIGEST=sha256:replace-with-release-api-image-digest
BREEZE_WEB_IMAGE_DIGEST=sha256:replace-with-release-web-image-digest
BREEZE_BINARIES_IMAGE_DIGEST=sha256:replace-with-release-binaries-image-digest

# Third-party runtime images must also be digest pinned.
CADDY_IMAGE_REF=caddy@sha256:replace-with-reviewed-caddy-image-digest
CLOUDFLARED_IMAGE_REF=cloudflare/cloudflared@sha256:replace-with-reviewed-cloudflared-image-digest
REDIS_IMAGE_REF=redis@sha256:replace-with-reviewed-redis-image-digest
COTURN_IMAGE_REF=coturn/coturn@sha256:replace-with-reviewed-coturn-image-digest
BILLING_IMAGE_REF=ghcr.io/lanternops/breeze-billing@sha256:replace-with-release-billing-image-digest

# Cloudflare Tunnel edge trust. The production compose assigns fixed container
# IPs so Caddy trusts only cloudflared, and the API trusts only Caddy.
BREEZE_DOCKER_SUBNET=172.30.0.0/24
BREEZE_CLOUDFLARED_IP=172.30.0.10
BREEZE_CADDY_IP=172.30.0.11
CADDY_TRUSTED_PROXIES=172.30.0.10/32
CADDY_CLIENT_IP_HEADERS=CF-Connecting-IP X-Forwarded-For
TRUSTED_PROXY_CIDRS=172.30.0.11/32

# ── Database (Managed Postgres) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
# Unprivileged app role (RLS enforced). Set ONE of these:
BREEZE_APP_DB_PASSWORD=
# DATABASE_URL_APP=postgresql://app_user:password@host:port/dbname?sslmode=require

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
AGENT_ENROLLMENT_SECRET=
APP_ENCRYPTION_KEY=
MFA_ENCRYPTION_KEY=
ENROLLMENT_KEY_PEPPER=
MFA_RECOVERY_CODE_PEPPER=
RELEASE_ARTIFACT_MANIFEST_PUBLIC_KEYS=

# Kill-switches for the launch-readiness MFA and lockout features.
# Defaults are secure (gate ON, lockout 5-in-15min). Operators can flip
# either off without a code deploy if an enrollment outage or stuck-out
# lockout needs immediate relief.
# MFA_FORCE_FOR_PARTNER_ADMIN=true
# LOGIN_ACCOUNT_LOCKOUT_MAX=5        # 0 disables per-account lockout entirely
# LOGIN_ACCOUNT_LOCKOUT_WINDOW_SECONDS=900

# Initial admin for a production database with no users. Leave blank after the
# bootstrap admin has logged in and completed setup. The API refuses to seed an
# empty production database unless both values are provided by the operator.
# Generate a one-time password when needed:
#   BREEZE_BOOTSTRAP_ADMIN_PASSWORD="$(openssl rand -base64 32)"
BREEZE_BOOTSTRAP_ADMIN_EMAIL=
BREEZE_BOOTSTRAP_ADMIN_PASSWORD=
# BREEZE_BOOTSTRAP_ADMIN_NAME=Owner Admin

# ── Email ───────────────────────────────────────────────────────────
EMAIL_PROVIDER=auto
RESEND_API_KEY=
EMAIL_FROM=noreply@2breeze.app
# SMTP (if not using Resend)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Billing ─────────────────────────────────────────────────────────
BILLING_SERVICE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_COMMUNITY_PRICE_ID=

# ── Observability ───────────────────────────────────────────────────
LOG_LEVEL=info
METRICS_SCRAPE_TOKEN=
SENTRY_DSN=

# Public self-service registration is opt-in for production/self-hosted deploys.
ENABLE_REGISTRATION=false
PUBLIC_ENABLE_REGISTRATION=false

# ── AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Object Storage (S3-compatible) ──────────────────────────────────
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=
# S3_PRESIGN_TTL=900

# ── WebRTC TURN (opt-in: COMPOSE_PROFILES=turn) ────────────────────
# TURN_HOST=
# TURN_PORT=3478
# TURN_SECRET=
# TURN_REALM=breeze.local
# TURN_CREDENTIAL_TTL_SECONDS=600
# TURN_MAX_BPS=5000000

# ── MSI Signing (optional) ─────────────────────────────────────────
# MSI_SIGNING_URL=
# MSI_SIGNING_CF_ACCESS_ID=
# MSI_SIGNING_CF_ACCESS_SECRET=
